# ─── General ───────────────────────────────────────────
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Service Ports ─────────────────────────────────────
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
BOOKING_SERVICE_PORT=4003
CHAT_SERVICE_PORT=4004
NOTIFICATION_SERVICE_PORT=4005
REALTIME_SERVICE_PORT=4006

# ─── Frontend ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4006

# ─── Email (Phase 3) ──────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
